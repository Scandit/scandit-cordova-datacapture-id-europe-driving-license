<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0" id="scandit-cordova-datacapture-id-europe-driving-license" version="8.4.1">
    <name>ScanditIdEuropeDrivingLicense</name>
    <engines>
        <engine name="cordova-ios" version=">=5.0.0" />
        <engine name="cordova-android" version=">=10.0.0" />
    </engines>
    <platform name="ios" package="swift">
        <config-file parent="/*" target="config.xml">
            <feature name="ScanditIdEuropeDrivingLicense">
                <param name="ios-package" value="ScanditIdEuropeDrivingLicensePlugin" />
                <param name="onload" value="false" />
            </feature>
        </config-file>
        <header-file src="src/ios/ScanditIdEuropeDrivingLicensePlugin-Bridging-Header.h" type="BridgingHeader" />
        <source-file src="src/ios/ScanditIdEuropeDrivingLicensePlugin.swift" />
        <podspec>
            <pods use-frameworks="true">
                <pod name="ScanditIdEuropeDrivingLicense" nospm="true" spec="= 8.4.1" />
            </pods>
        </podspec>
        <hook src="src/hooks/patch-spm-deployment-target.js" type="after_plugin_install" />
    </platform>
    <platform name="android">
        <config-file parent="/*" target="config.xml">
            <feature name="ScanditIdEuropeDrivingLicense">
                <param name="android-package" value="com.scandit.datacapture.cordova.ideuropedrivinglicense.ScanditIdEuropeDrivingLicense" />
            </feature>
        </config-file>
        <source-file src="src/android/ScanditIdEuropeDrivingLicense.kt" target-dir="kotlin/com/scandit/datacapture/cordova/ideuropedrivinglicense" />
        <framework custom="true" src="src/android/build.gradle" type="gradleReference" />
        <hook src="src/hooks/support-kotlin.js" type="after_plugin_install" />
    </platform>
</plugin>